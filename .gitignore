# 기본적으로 모든 파일 무시 (이 폴더에 비즈니스 문서가 많음)
*

# 우리 작업 폴더만 화이트리스트
!.gitignore
!.claude/
!.claude/**
!premiere_agent/
!premiere_agent/**
!scene_splitter/
!scene_splitter/**
!premiere_ai_panel/
!premiere_ai_panel/**

# 작업 폴더 안에서도 민감 파일 / 빌드 산출물 제외
**/.env
**/__pycache__/
**/*.pyc
**/*.pyo
premiere_agent/lib/
**/node_modules/
**/.DS_Store
**/Thumbs.db
